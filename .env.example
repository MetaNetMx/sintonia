# Variables de entorno — SOLO server-side (funciones serverless en api/).
# NUNCA se exponen al cliente. No uses el prefijo VITE_ con estas claves:
# cualquier variable VITE_* queda embebida en el bundle del navegador.
# Copia este archivo a .env.local y rellena los valores. .env.local esta en .gitignore.

# Clave de Anthropic (IA de acompanamiento). Server-side.
ANTHROPIC_API_KEY=

# Modelo por defecto de Anthropic.
ANTHROPIC_MODEL=claude-sonnet-5

# Clave de ElevenLabs (voz / TTS / clonacion). Server-side.
ELEVENLABS_API_KEY=
